services:
  uptime-kuma-restly:
    build:
      context: .
      dockerfile: Dockerfile
    image: uptime-kuma-restly:latest
    container_name: uptime-kuma-restly
    restart: unless-stopped
    ports:
      - "9911:9911"
    env_file:
      - .env
    healthcheck:
      test:
        - CMD-SHELL
        - curl -fsS http://127.0.0.1:9911/api/health >/dev/null
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 30s
