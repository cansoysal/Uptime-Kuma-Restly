services:
  uptime-kuma-bridge:
    build:
      context: .
      dockerfile: docker/combined.Dockerfile
      args:
        UPTIME_KUMA_TAG: ${UPTIME_KUMA_TAG:-2}
    image: uptime-kuma-bridge:latest
    container_name: uptime-kuma-bridge
    restart: unless-stopped
    ports:
      - "3001:3001"
      - "9911:9911"
    env_file:
      - .env
    volumes:
      - kuma-data:/app/data
    healthcheck:
      test:
        - CMD-SHELL
        - curl -fsS http://127.0.0.1:9911/api/health >/dev/null && curl -fsS http://127.0.0.1:3001/ >/dev/null
      interval: 30s
      timeout: 10s
      retries: 10
      start_period: 120s

volumes:
  kuma-data:
